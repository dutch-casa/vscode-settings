{
  // ── Editor ──────────────────────────────────────────────────
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'JetBrains Mono', monospace",
  "editor.fontLigatures": true,
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.rulers": [80],
  "editor.scrollBeyondLastLine": true,
  "editor.stickyScroll.enabled": true,
  "editor.cursorSurroundingLines": 8,

  // ── Vim (matching nvim keymaps.lua) ─────────────────────────
  // d/c/x go to black hole — never clobber clipboard
  "vim.normalModeKeyBindingsNonRecursive": [
    // ── Flash-like jump (s{char}{char}) ───────────────────────
    { "before": ["s"], "after": ["<leader>", "<leader>", "2", "s"] },
    { "before": ["S"], "after": ["<leader>", "<leader>", "s"] },

    // ── Black hole register (keymaps.lua) ─────────────────────
    { "before": ["d", "d"], "after": ["\"", "_", "d", "d"] },
    { "before": ["D"], "after": ["\"", "_", "D"] },
    { "before": ["C"], "after": ["\"", "_", "C"] },
    { "before": ["x"], "after": ["\"", "_", "x"] },
    { "before": ["X"], "after": ["\"", "_", "X"] },
    { "before": ["<leader>", "d"], "after": ["\"", "+", "d"] },
    { "before": ["<leader>", "D"], "after": ["\"", "+", "D"] },

    // ── Window navigation (ctrl+hjkl) ─────────────────────────
    { "before": ["<C-h>"], "commands": ["workbench.action.focusLeftGroup"] },
    { "before": ["<C-j>"], "commands": ["workbench.action.focusBelowGroup"] },
    { "before": ["<C-k>"], "commands": ["workbench.action.focusAboveGroup"] },
    { "before": ["<C-l>"], "commands": ["workbench.action.focusRightGroup"] },

    // ── Buffers (S-h / S-l) ───────────────────────────────────
    { "before": ["<S-h>"], "commands": ["workbench.action.previousEditor"] },
    { "before": ["<S-l>"], "commands": ["workbench.action.nextEditor"] },
    { "before": ["[", "b"], "commands": ["workbench.action.previousEditor"] },
    { "before": ["]", "b"], "commands": ["workbench.action.nextEditor"] },
    { "before": ["<leader>", "b", "b"], "commands": ["workbench.action.quickOpenPreviousRecentlyUsedEditor"] },
    { "before": ["<leader>", "`"], "commands": ["workbench.action.quickOpenPreviousRecentlyUsedEditor"] },
    { "before": ["<leader>", "b", "d"], "commands": ["workbench.action.closeActiveEditor"] },
    { "before": ["<leader>", "b", "o"], "commands": ["workbench.action.closeOtherEditors"] },
    { "before": ["<leader>", "b", "D"], "commands": ["workbench.action.closeEditorsInGroup"] },

    // ── Splits (leader - / |) ─────────────────────────────────
    { "before": ["<leader>", "-"], "commands": ["workbench.action.splitEditorDown"] },
    { "before": ["<leader>", "|"], "commands": ["workbench.action.splitEditorRight"] },
    { "before": ["<leader>", "w", "d"], "commands": ["workbench.action.closeGroup"] },
    { "before": ["<leader>", "w", "m"], "commands": ["workbench.action.toggleMaximizeEditorGroup"] },

    // ── LSP / Code ────────────────────────────────────────────
    { "before": ["g", "d"], "commands": ["editor.action.revealDefinition"] },
    { "before": ["g", "D"], "commands": ["editor.action.peekDefinition"] },
    { "before": ["g", "r"], "commands": ["editor.action.goToReferences"] },
    { "before": ["g", "I"], "commands": ["editor.action.goToImplementation"] },
    { "before": ["g", "t"], "commands": ["editor.action.goToTypeDefinition"] },
    { "before": ["K"], "commands": ["editor.action.showHover"] },
    { "before": ["<leader>", "c", "a"], "commands": ["editor.action.quickFix"] },
    { "before": ["<leader>", "c", "r"], "commands": ["editor.action.rename"] },
    { "before": ["<leader>", "c", "f"], "commands": ["editor.action.formatDocument"] },
    { "before": ["<leader>", "c", "d"], "commands": ["editor.action.showHover"] },
    { "before": ["<leader>", "c", "h"], "commands": ["clangd.switchheadersource"] },
    { "before": ["<leader>", "c", "o"], "commands": ["editor.action.organizeImports"] },

    // ── Diagnostics ───────────────────────────────────────────
    { "before": ["]", "d"], "commands": ["editor.action.marker.next"] },
    { "before": ["[", "d"], "commands": ["editor.action.marker.prev"] },
    { "before": ["]", "e"], "commands": ["editor.action.marker.nextInFiles"] },
    { "before": ["[", "e"], "commands": ["editor.action.marker.prevInFiles"] },

    // ── Quickfix ──────────────────────────────────────────────
    { "before": ["]", "q"], "commands": ["search.action.focusNextSearchResult"] },
    { "before": ["[", "q"], "commands": ["search.action.focusPreviousSearchResult"] },
    { "before": ["<leader>", "x", "q"], "commands": ["workbench.action.togglePanel"] },

    // ── Search / Pickers (leader f) ───────────────────────────
    { "before": ["<leader>", "f", "f"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["<leader>", "f", "g"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["<leader>", "f", "n"], "commands": ["workbench.action.files.newUntitledFile"] },
    { "before": ["<leader>", "f", "r"], "commands": ["workbench.action.openRecent"] },
    { "before": ["<leader>", "f", "t"], "commands": ["workbench.action.terminal.toggleTerminal"] },
    { "before": ["<leader>", "f", "T"], "commands": ["workbench.action.terminal.new"] },

    // ── Refactor (leader r) — matches refactoring.nvim ────────
    { "before": ["<leader>", "r", "s"], "commands": ["editor.action.refactor"] },
    { "before": ["<leader>", "r", "f"], "commands": ["editor.action.extractMethod"] },
    { "before": ["<leader>", "r", "x"], "commands": ["editor.action.extractVariable"] },
    { "before": ["<leader>", "r", "i"], "commands": ["editor.action.inlineVariable"] },
    { "before": ["<leader>", "r", "r"], "commands": ["editor.action.rename"] },

    // ── Sidebar / Explorer ────────────────────────────────────
    { "before": ["<leader>", "e"], "commands": ["workbench.action.toggleSidebarVisibility"] },

    // ── Git (leader g) ────────────────────────────────────────
    { "before": ["<leader>", "g", "b"], "commands": ["gitlens.toggleLineBlame"] },
    { "before": ["<leader>", "g", "l"], "commands": ["gitlens.showGraph"] },
    { "before": ["<leader>", "g", "f"], "commands": ["gitlens.showFileHistoryView"] },
    { "before": ["<leader>", "g", "B"], "commands": ["gitlens.openFileOnRemote"] },

    // ── Debug (leader d) ──────────────────────────────────────
    { "before": ["<leader>", "d", "b"], "commands": ["editor.debug.action.toggleBreakpoint"] },
    { "before": ["<leader>", "d", "B"], "commands": ["editor.debug.action.conditionalBreakpoint"] },
    { "before": ["<leader>", "d", "c"], "commands": ["workbench.action.debug.continue"] },
    { "before": ["<leader>", "d", "s"], "commands": ["workbench.action.debug.stepOver"] },
    { "before": ["<leader>", "d", "i"], "commands": ["workbench.action.debug.stepInto"] },
    { "before": ["<leader>", "d", "o"], "commands": ["workbench.action.debug.stepOut"] },
    { "before": ["<leader>", "d", "t"], "commands": ["workbench.action.debug.stop"] },
    { "before": ["<leader>", "d", "r"], "commands": ["workbench.action.debug.restart"] },
    { "before": ["<leader>", "d", "l"], "commands": ["workbench.action.debug.run"] },

    // ── Toggles (leader u) ────────────────────────────────────
    { "before": ["<leader>", "u", "w"], "commands": ["editor.action.toggleWordWrap"] },
    { "before": ["<leader>", "u", "h"], "commands": ["editor.action.toggleInlayHints"] },
    { "before": ["<leader>", "u", "l"], "commands": ["workbench.action.toggleLineNumbers"] },
    { "before": ["<leader>", "u", "z"], "commands": ["workbench.action.toggleZenMode"] },
    { "before": ["<leader>", "u", "s"], "commands": ["editor.action.toggleStickyScroll"] },
    { "before": ["<leader>", "u", "m"], "commands": ["editor.action.toggleMinimap"] },

    // ── Tabs (leader tab) ─────────────────────────────────────
    { "before": ["<leader>", "<tab>", "<tab>"], "commands": ["workbench.action.newGroupEditor"] },
    { "before": ["<leader>", "<tab>", "d"], "commands": ["workbench.action.closeGroup"] },
    { "before": ["<leader>", "<tab>", "]"], "commands": ["workbench.action.nextEditorInGroup"] },
    { "before": ["<leader>", "<tab>", "["], "commands": ["workbench.action.previousEditorInGroup"] },

    // ── Quit ──────────────────────────────────────────────────
    { "before": ["<leader>", "q", "q"], "commands": ["workbench.action.closeWindow"] },

    // ── Markdown preview ──────────────────────────────────────
    { "before": ["<leader>", "c", "p"], "commands": ["markdown.showPreviewToSide"] }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    // Flash-like jump in visual mode
    { "before": ["s"], "after": ["<leader>", "<leader>", "2", "s"] },
    // Black hole register
    { "before": ["d"], "after": ["\"", "_", "d"] },
    { "before": ["c"], "after": ["\"", "_", "c"] },
    { "before": ["x"], "after": ["\"", "_", "x"] },
    { "before": ["X"], "after": ["\"", "_", "X"] },
    { "before": ["p"], "after": ["\"", "_", "d", "P"] },
    { "before": ["<leader>", "d"], "after": ["\"", "+", "d"] },
    // Better indenting (stay in visual after indent)
    { "before": ["<"], "after": ["<", "g", "v"] },
    { "before": [">"], "after": [">", "g", "v"] },
    // Format selection
    { "before": ["<leader>", "c", "f"], "commands": ["editor.action.formatSelection"] },
    // Refactor
    { "before": ["<leader>", "r", "s"], "commands": ["editor.action.refactor"] },
    { "before": ["<leader>", "r", "f"], "commands": ["editor.action.extractMethod"] },
    { "before": ["<leader>", "r", "x"], "commands": ["editor.action.extractVariable"] },
    { "before": ["<leader>", "r", "i"], "commands": ["editor.action.inlineVariable"] },
    // Git browse selection
    { "before": ["<leader>", "g", "B"], "commands": ["gitlens.openFileOnRemote"] }
  ],
  "vim.insertModeKeyBindingsNonRecursive": [
    { "before": ["j", "k"], "after": ["<Esc>"] },
    { "before": ["j", "j"], "after": ["<Esc>"] }
  ],
  "vim.leader": "<space>",
  "vim.useSystemClipboard": false,
  "vim.hlsearch": true,
  "vim.smartRelativeLine": true,
  "vim.timeout": 200,

  // ── Flash-like jump (easymotion) ────────────────────────────
  // s{char}{char} jumps anywhere visible — like flash.nvim in LazyVim
  "vim.easymotion": true,
  "vim.easymotionMarkerBackgroundColor": "#7e57c2",
  "vim.easymotionMarkerForegroundColorOneChar": "#ffffff",
  "vim.easymotionMarkerForegroundColorTwoCharFirst": "#ffffff",
  "vim.easymotionMarkerForegroundColorTwoCharSecond": "#ffffff",

  // ── Which Key ───────────────────────────────────────────────
  "whichkey.delay": 300,
  "whichkey.sortOrder": "alphabetically",
  "whichkey.bindings": [
    { "key": "b", "name": "+buffer", "type": "bindings", "bindings": [
      { "key": "b", "name": "Switch buffer", "type": "command", "command": "workbench.action.quickOpenPreviousRecentlyUsedEditor" },
      { "key": "d", "name": "Close buffer", "type": "command", "command": "workbench.action.closeActiveEditor" },
      { "key": "o", "name": "Close others", "type": "command", "command": "workbench.action.closeOtherEditors" },
      { "key": "D", "name": "Close all in group", "type": "command", "command": "workbench.action.closeEditorsInGroup" }
    ]},
    { "key": "c", "name": "+code", "type": "bindings", "bindings": [
      { "key": "a", "name": "Code action", "type": "command", "command": "editor.action.quickFix" },
      { "key": "d", "name": "Line diagnostics", "type": "command", "command": "editor.action.showHover" },
      { "key": "f", "name": "Format", "type": "command", "command": "editor.action.formatDocument" },
      { "key": "h", "name": "Switch header/source", "type": "command", "command": "clangd.switchheadersource" },
      { "key": "o", "name": "Organize imports", "type": "command", "command": "editor.action.organizeImports" },
      { "key": "p", "name": "Markdown preview", "type": "command", "command": "markdown.showPreviewToSide" },
      { "key": "r", "name": "Rename symbol", "type": "command", "command": "editor.action.rename" }
    ]},
    { "key": "d", "name": "+debug", "type": "bindings", "bindings": [
      { "key": "b", "name": "Toggle breakpoint", "type": "command", "command": "editor.debug.action.toggleBreakpoint" },
      { "key": "B", "name": "Conditional breakpoint", "type": "command", "command": "editor.debug.action.conditionalBreakpoint" },
      { "key": "c", "name": "Continue", "type": "command", "command": "workbench.action.debug.continue" },
      { "key": "i", "name": "Step into", "type": "command", "command": "workbench.action.debug.stepInto" },
      { "key": "l", "name": "Run (no debug)", "type": "command", "command": "workbench.action.debug.run" },
      { "key": "o", "name": "Step out", "type": "command", "command": "workbench.action.debug.stepOut" },
      { "key": "r", "name": "Restart", "type": "command", "command": "workbench.action.debug.restart" },
      { "key": "s", "name": "Step over", "type": "command", "command": "workbench.action.debug.stepOver" },
      { "key": "t", "name": "Stop", "type": "command", "command": "workbench.action.debug.stop" }
    ]},
    { "key": "e", "name": "Explorer", "type": "command", "command": "workbench.action.toggleSidebarVisibility" },
    { "key": "f", "name": "+find/file", "type": "bindings", "bindings": [
      { "key": "f", "name": "Find file", "type": "command", "command": "workbench.action.quickOpen" },
      { "key": "g", "name": "Grep in files", "type": "command", "command": "workbench.action.findInFiles" },
      { "key": "n", "name": "New file", "type": "command", "command": "workbench.action.files.newUntitledFile" },
      { "key": "r", "name": "Recent files", "type": "command", "command": "workbench.action.openRecent" },
      { "key": "t", "name": "Terminal", "type": "command", "command": "workbench.action.terminal.toggleTerminal" },
      { "key": "T", "name": "New terminal", "type": "command", "command": "workbench.action.terminal.new" }
    ]},
    { "key": "g", "name": "+git", "type": "bindings", "bindings": [
      { "key": "b", "name": "Blame line", "type": "command", "command": "gitlens.toggleLineBlame" },
      { "key": "B", "name": "Open on remote", "type": "command", "command": "gitlens.openFileOnRemote" },
      { "key": "f", "name": "File history", "type": "command", "command": "gitlens.showFileHistoryView" },
      { "key": "l", "name": "Git graph", "type": "command", "command": "gitlens.showGraph" }
    ]},
    { "key": "r", "name": "+refactor", "type": "bindings", "bindings": [
      { "key": "f", "name": "Extract function", "type": "command", "command": "editor.action.extractMethod" },
      { "key": "x", "name": "Extract variable", "type": "command", "command": "editor.action.extractVariable" },
      { "key": "i", "name": "Inline variable", "type": "command", "command": "editor.action.inlineVariable" },
      { "key": "r", "name": "Rename", "type": "command", "command": "editor.action.rename" },
      { "key": "s", "name": "Refactor menu", "type": "command", "command": "editor.action.refactor" }
    ]},
    { "key": "q", "name": "+quit", "type": "bindings", "bindings": [
      { "key": "q", "name": "Quit", "type": "command", "command": "workbench.action.closeWindow" }
    ]},
    { "key": "u", "name": "+toggle", "type": "bindings", "bindings": [
      { "key": "h", "name": "Inlay hints", "type": "command", "command": "editor.action.toggleInlayHints" },
      { "key": "l", "name": "Line numbers", "type": "command", "command": "workbench.action.toggleLineNumbers" },
      { "key": "m", "name": "Minimap", "type": "command", "command": "editor.action.toggleMinimap" },
      { "key": "s", "name": "Sticky scroll", "type": "command", "command": "editor.action.toggleStickyScroll" },
      { "key": "w", "name": "Word wrap", "type": "command", "command": "editor.action.toggleWordWrap" },
      { "key": "z", "name": "Zen mode", "type": "command", "command": "workbench.action.toggleZenMode" }
    ]},
    { "key": "w", "name": "+window", "type": "bindings", "bindings": [
      { "key": "d", "name": "Close window", "type": "command", "command": "workbench.action.closeGroup" },
      { "key": "m", "name": "Maximize", "type": "command", "command": "workbench.action.toggleMaximizeEditorGroup" },
      { "key": "-", "name": "Split below", "type": "command", "command": "workbench.action.splitEditorDown" },
      { "key": "|", "name": "Split right", "type": "command", "command": "workbench.action.splitEditorRight" }
    ]}
  ],

  // ── C++ (clangd) ───────────────────────────────────────────
  // Disable Microsoft IntelliSense — clangd handles everything.
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.default.compilerPath": "/usr/bin/gcc",
  "clangd.path": "/opt/homebrew/opt/llvm/bin/clangd",
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--header-insertion=iwyu",
    "--completion-style=detailed",
    "--function-arg-placeholders",
    "--fallback-flags=-std=c++23",
    "--pch-storage=memory",
    "--all-scopes-completion",
    "--header-insertion-decorators"
  ],

  // ── Go ──────────────────────────────────────────────────────
  "go.useLanguageServer": true,
  "gopls": {
    "formatting.gofumpt": true,
    "ui.semanticTokens": true,
    "ui.completion.usePlaceholders": true,
    "ui.diagnostic.staticcheck": true,
    "ui.diagnostic.analyses": {
      "shadow": true,
      "nilness": true,
      "unusedparams": true,
      "unusedwrite": true,
      "useany": true
    },
    "ui.inlayhint.hints": {
      "assignVariableTypes": true,
      "compositeLiteralFields": true,
      "compositeLiteralTypes": true,
      "constantValues": true,
      "functionTypeParameters": true,
      "parameterNames": true,
      "rangeVariableTypes": true
    },
    "ui.codelenses": {
      "gc_details": true,
      "generate": true,
      "regenerate_cgo": true,
      "run_govulncheck": true,
      "test": true,
      "tidy": true,
      "upgrade_dependency": true,
      "vendor": true
    }
  },
  "go.lintTool": "golangci-lint",
  "go.lintFlags": ["--fast"],
  "go.formatTool": "gofumpt",

  // ── TypeScript / React ──────────────────────────────────────
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.quoteStyle": "single",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.completeFunctionCalls": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "javascript.inlayHints.parameterNames.enabled": "all",
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.enumMemberValues.enabled": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.suggest.completeFunctionCalls": true,

  // ── Per-language formatters ─────────────────────────────────
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },

  // ── Git ─────────────────────────────────────────────────────
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",

  // ── Workbench ───────────────────────────────────────────────
  "workbench.colorTheme": "Dark Modern",
  "workbench.iconTheme": "vscode-icons",
  // ── Wildcharm color matching ────────────────────────────────
  "workbench.colorCustomizations": {
    "editor.background": "#000000",
    "editor.foreground": "#d0d0d0",
    "editorCursor.foreground": "#ffffff",
    "editor.lineHighlightBackground": "#262626",
    "editor.selectionBackground": "#005f87",
    "editorLineNumber.foreground": "#585858",
    "editorLineNumber.activeForeground": "#ffffff",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#d0d0d0",
    "sideBarSectionHeader.background": "#000000",
    "activityBar.background": "#000000",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#d0d0d0",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#9e9e9e",
    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#000000",
    "tab.activeForeground": "#d0d0d0",
    "tab.inactiveForeground": "#767676",
    "panel.background": "#000000",
    "terminal.background": "#000000",
    "terminal.foreground": "#d0d0d0",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#d7005f",
    "terminal.ansiGreen": "#00af5f",
    "terminal.ansiYellow": "#d78700",
    "terminal.ansiBlue": "#0087d7",
    "terminal.ansiMagenta": "#d787d7",
    "terminal.ansiCyan": "#00afaf",
    "terminal.ansiWhite": "#d0d0d0",
    "terminal.ansiBrightBlack": "#767676",
    "terminal.ansiBrightRed": "#ff5f87",
    "terminal.ansiBrightGreen": "#00d75f",
    "terminal.ansiBrightYellow": "#ffaf00",
    "terminal.ansiBrightBlue": "#00afff",
    "terminal.ansiBrightMagenta": "#ff87ff",
    "terminal.ansiBrightCyan": "#00d7d7",
    "terminal.ansiBrightWhite": "#ffffff",
    "editorWidget.background": "#303030",
    "editorSuggestWidget.background": "#303030",
    "editorSuggestWidget.foreground": "#d0d0d0",
    "editorSuggestWidget.selectedBackground": "#585858",
    "list.activeSelectionBackground": "#585858",
    "list.hoverBackground": "#303030",
    "input.background": "#303030",
    "dropdown.background": "#303030",
    "editorGutter.addedBackground": "#00af5f",
    "editorGutter.modifiedBackground": "#0087d7",
    "editorGutter.deletedBackground": "#d7005f",
    "gitDecoration.addedResourceForeground": "#00af5f",
    "gitDecoration.modifiedResourceForeground": "#0087d7",
    "gitDecoration.deletedResourceForeground": "#d7005f",
    "editorError.foreground": "#d7005f",
    "editorWarning.foreground": "#ffaf00",
    "editorInfo.foreground": "#00afff",
    "focusBorder": "#585858",
    "editorRuler.foreground": "#303030",
    "editorIndentGuide.background1": "#303030",
    "editorBracketMatch.border": "#ff00af"
  },
  "editor.tokenColorCustomizations": {
    "comments": "#767676",
    "strings": "#00d75f",
    "keywords": "#00afff",
    "numbers": "#ff5f87",
    "types": "#ffaf00",
    "functions": "#ff87ff",
    "variables": "#d0d0d0",
    "textMateRules": [
      {
        "scope": ["constant", "constant.numeric", "constant.language"],
        "settings": { "foreground": "#ff5f87" }
      },
      {
        "scope": ["entity.name.function", "support.function"],
        "settings": { "foreground": "#ff87ff" }
      },
      {
        "scope": ["entity.name.type", "support.type", "support.class"],
        "settings": { "foreground": "#ffaf00" }
      },
      {
        "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
        "settings": { "foreground": "#00afff" }
      },
      {
        "scope": ["string", "string.quoted"],
        "settings": { "foreground": "#00d75f" }
      },
      {
        "scope": ["variable", "variable.other", "variable.parameter"],
        "settings": { "foreground": "#d0d0d0" }
      },
      {
        "scope": ["entity.name.tag", "punctuation.definition.tag"],
        "settings": { "foreground": "#00afff" }
      },
      {
        "scope": ["entity.other.attribute-name"],
        "settings": { "foreground": "#ffaf00" }
      },
      {
        "scope": ["meta.preprocessor", "keyword.control.directive"],
        "settings": { "foreground": "#00d7d7" }
      },
      {
        "scope": ["punctuation.special", "keyword.operator"],
        "settings": { "foreground": "#875fff" }
      },
      {
        "scope": ["comment", "punctuation.definition.comment"],
        "settings": { "foreground": "#767676" }
      },
      {
        "scope": ["markup.deleted"],
        "settings": { "foreground": "#d7005f" }
      },
      {
        "scope": ["markup.inserted"],
        "settings": { "foreground": "#00af5f" }
      },
      {
        "scope": ["markup.changed"],
        "settings": { "foreground": "#0087d7" }
      }
    ]
  },
  "workbench.startupEditor": "none",
  "workbench.editor.editorActionsLocation": "titleBar",
  "workbench.editor.showTabs": "single",
  "workbench.experimental.share.enabled": true,
  "update.showReleaseNotes": false,
  "chat.commandCenter.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",

  // ── LaTeX ───────────────────────────────────────────────────
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (lualatex)",
      "tools": ["lualatexmk"]
    },
    {
      "name": "latexmk (xelatex)",
      "tools": ["xelatexmk"]
    },
    {
      "name": "latexmk (pdflatex)",
      "tools": ["pdflatexmk"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "lualatexmk",
      "command": "latexmk",
      "args": ["-lualatex", "-synctex=1", "-interaction=nonstopmode", "-file-line-error", "%DOC%"]
    },
    {
      "name": "xelatexmk",
      "command": "latexmk",
      "args": ["-xelatex", "-synctex=1", "-interaction=nonstopmode", "-file-line-error", "%DOC%"]
    },
    {
      "name": "pdflatexmk",
      "command": "latexmk",
      "args": ["-pdf", "-synctex=1", "-interaction=nonstopmode", "-file-line-error", "%DOC%"]
    }
  ],
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux", "*.bbl", "*.blg", "*.idx", "*.ind", "*.lof", "*.lot",
    "*.out", "*.toc", "*.acn", "*.acr", "*.alg", "*.glg", "*.glo",
    "*.gls", "*.fls", "*.log", "*.fdb_latexmk", "*.snm", "*.synctex(busy)",
    "*.synctex.gz", "*.nav", "*.vrb"
  ],
  "latex-workshop.intellisense.citation.backend": "biblatex",
  "[latex]": {
    "editor.defaultFormatter": "james-yu.latex-workshop",
    "editor.wordWrap": "on",
    "editor.formatOnSave": false
  },

  // ── Biome ───────────────────────────────────────────────────
  "biome.suggestInstallingGlobally": false,

  // ── Kill all AI chat/copilot ────────────────────────────────
  "github.copilot.enable": {
    "*": false
  },
  "github.copilot.chat.enabled": false,
  "github.copilot.renameSuggestions.triggerAutomatically": false,
  "chat.commandCenter.enabled": false,
  "chat.editor.enabled": false,
  "chat.enabled": false,
  "chat.panel.defaultMode": "hidden",
  "chat.agent.enabled": false,
  "workbench.panel.chat.defaultVisibility": "hidden",
  "workbench.secondarySideBar.visible": false,


  // ── Python ──────────────────────────────────────────────────
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",

  // ── File nesting ────────────────────────────────────────────
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "pubspec.yaml": "pubspec.lock,pubspec_overrides.yaml,.packages,.flutter-plugins,.flutter-plugins-dependencies,.metadata",
    "*.dart": "${capture}.g.dart",
    "*.fs": "${basename}.fsi, ${basename}.fs.js, ${basename}.fs.js.map",
    "*.fsl": "${basename}.fsi, ${basename}.fs",
    "*.fsy": "${basename}.fsi, ${basename}.fs",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },

  // ── Misc ────────────────────────────────────────────────────
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true
  },
  "chat.instructionsFilesLocations": {
    ".github/instructions": true
  },
  "chat.disableAIFeatures": true,
  "claudeCode.preferredLocation": "panel",
  "editor.minimap.size": "fill",
  "editor.minimap.showSlider": "always",
  "editor.minimap.enabled": false
}
